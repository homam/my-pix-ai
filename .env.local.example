# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Astria.ai
ASTRIA_API_KEY=your-astria-api-key
# Webhook secret to validate Astria callbacks (set to any random string, then configure in Astria dashboard)
ASTRIA_WEBHOOK_SECRET=your-webhook-secret

# Cloudflare R2
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=my-pix-ai
R2_PUBLIC_URL=https://your-bucket.your-domain.com

# Stripe
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Credit pack price IDs (create in Stripe dashboard)
STRIPE_PRICE_STARTER=price_...   # 50 credits = $9
STRIPE_PRICE_PRO=price_...       # 200 credits = $29
STRIPE_PRICE_ULTRA=price_...     # 500 credits = $59

# Resend (email)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=hello@mypix.ai

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
