# ============================================================
# Supabase (required)
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================================
# Astria.ai (required — sign up at astria.ai and get an API key)
# ============================================================
ASTRIA_API_KEY=sk_...

# Used as a shared secret between Astria and this app. Can be any random string.
# Only matters if you configure the webhook (see below).
ASTRIA_WEBHOOK_SECRET=change-me-to-a-random-string

# (Optional) Public URL that Astria can POST training-completion webhooks to.
# - Leave UNSET for local dev — the UI polls training status automatically.
# - For production, set to your deployed URL (e.g. https://mypix.ai)
#   or, for local dev with live webhooks, use an ngrok URL (see CLAUDE.md).
# ASTRIA_WEBHOOK_PUBLIC_URL=https://your-app.ngrok-free.app

# ============================================================
# App
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Set to "false" in production to disable the dev /api/dev/grant-credits endpoint.
DEV_GRANT_CREDITS=true
