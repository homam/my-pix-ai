# ============================================================
# Supabase (required)
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================================
# Astria.ai (required — sign up at astria.ai and get an API key)
# ============================================================
ASTRIA_API_KEY=sk_...

# Shared secret between Astria and this app. Any random string.
# Only consulted if webhooks are enabled (see below).
ASTRIA_WEBHOOK_SECRET=change-me-to-a-random-string

# (Optional) Public URL for Astria training-completion webhooks.
# - Leave UNSET for local dev — the UI polls status instead.
# - For prod, set to your deployed URL (e.g. https://mypix.ai).
# - For local live-webhook dev, use ngrok (see CLAUDE.md).
# ASTRIA_WEBHOOK_PUBLIC_URL=https://your-app.ngrok-free.app

# ----------------------------------------------------------------
# Realism tuning for FLUX inference. These are the defaults used
# when the UI's "Realism" preset is "Natural". Changing these tunes
# every generation without redeploying. See lib/astria.ts.
# ----------------------------------------------------------------
# ASTRIA_CFG_SCALE=3            # 1.5–3 = natural skin; 5+ = stylized/plastic
# ASTRIA_STEPS=40               # 30–50; higher = more detail, slower
# ASTRIA_FILM_GRAIN=true        # adds grain — main anti-plastic-skin lever
# ASTRIA_FACE_CORRECT=false     # true smooths skin (the "plastic" cause)
# ASTRIA_SUPER_RES=false        # true upscales 4x but can re-smooth skin
# ASTRIA_REALISM_SUFFIX=        # set to empty string to disable; leave unset for built-in default

# Stack a public Astria FLUX realism LoRA on top of the user's identity LoRA.
# Verify the ID against an actual generation before enabling — bad IDs 422.
# ASTRIA_REALISM_LORA_ID=
# ASTRIA_REALISM_LORA_WEIGHT=0.5

# ============================================================
# App
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:4871

# Dev-only endpoint to grant yourself credits. Set "false" in prod.
DEV_GRANT_CREDITS=true

# ============================================================
# Stripe (optional — payments)
# Leave unset to disable checkout. The /pricing page will fall
# back to the dev-grant button when Stripe is not configured.
# ============================================================
# STRIPE_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_STARTER=price_...   # 50 credits / $9
# STRIPE_PRICE_PRO=price_...       # 200 credits / $29
# STRIPE_PRICE_ULTRA=price_...     # 500 credits / $59

# ============================================================
# Resend (optional — transactional email)
# Leave unset to disable email. Training-complete notifications
# will just log to the server console.
# ============================================================
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=hello@yourdomain.com
